#!/usr/bin/env python3
"""brlfetch — Bedrock Linux–exclusive system info, fastfetch-style."""

from __future__ import annotations

import argparse
import os
import re
import shutil
import subprocess
import sys
from dataclasses import dataclass
from typing import Optional

try:
    from rich.align import Align
    from rich.console import Console
    from rich.panel import Panel
    from rich.table import Table
    from rich.text import Text
except ImportError:
    sys.stderr.write(
        "brlfetch needs python-rich. Install via your distro pm:\n"
        "  arch: python-rich   fedora/debian: python3-rich   any: pip install --user rich\n"
    )
    sys.exit(1)

console = Console()


# ───────────────────────────────────────────────────────────────────────────
# Helpers
# ───────────────────────────────────────────────────────────────────────────

def run(cmd, timeout=5, **kw):
    kw.setdefault('stdout', subprocess.PIPE)
    kw.setdefault('stderr', subprocess.PIPE)
    kw.setdefault('text', True)
    try:
        return subprocess.run(cmd, timeout=timeout, **kw)
    except (subprocess.TimeoutExpired, FileNotFoundError):
        class R:
            returncode = 124
            stdout = ''
            stderr = ''
        return R()


def bail():
    console.print(Panel.fit(
        "[bold red]Theres nothing hijacked, go do it then fetch me.[/bold red]\n"
        "[dim](brlfetch is for Bedrock Linux systems only — see https://bedrocklinux.org)[/dim]",
        border_style='red',
    ))
    sys.exit(2)


def verify_bedrock():
    """5-signal Bedrock detection — same as brldoc, identical exit path."""
    signals = [
        os.path.isdir('/bedrock'),
        os.path.isdir('/bedrock/cross'),
        shutil.which('brl') is not None,
    ]
    if signals[-1]:
        r = run(['brl', 'version'], timeout=3)
        signals.append(r.returncode == 0 and 'Bedrock' in r.stdout)
        signals.append(bool(run(['brl', 'list'], timeout=3).stdout.strip()))
    if not all(signals):
        bail()


# ───────────────────────────────────────────────────────────────────────────
# Info gatherers
# ───────────────────────────────────────────────────────────────────────────

def get_bedrock_version() -> str:
    r = run(['brl', 'version'])
    return (r.stdout.strip() or 'unknown').splitlines()[0]


def get_hijacked_from() -> str:
    """Original distro that Bedrock hijacked, with its current version."""
    r = run(['brl', 'deref', 'hijacked'])
    stratum = r.stdout.strip() if r.returncode == 0 else ''
    if not stratum:
        return 'unknown'
    osrel = f'/bedrock/strata/{stratum}/etc/os-release'
    if not os.path.isfile(osrel):
        return stratum.capitalize()
    info: dict[str, str] = {}
    try:
        with open(osrel) as f:
            for line in f:
                if '=' in line:
                    k, v = line.split('=', 1)
                    info[k.strip()] = v.strip().strip('"\'')
    except OSError:
        return stratum.capitalize()
    name = info.get('PRETTY_NAME') or info.get('NAME', stratum.capitalize())
    version = info.get('VERSION_ID', '')
    if 'PRETTY_NAME' in info:
        return re.sub(r'\s*\([^)]*\)\s*$', '', name).strip()
    return f'{name} {version}'.strip()


def get_init_stratum() -> str:
    r = run(['brl', 'deref', 'init'])
    return r.stdout.strip() if r.returncode == 0 else 'unknown'


def detect_pm(stratum: str) -> Optional[str]:
    pms = ('pacman', 'dnf', 'apt-get', 'zypper', 'xbps-install', 'apk', 'emerge')
    for pm in pms:
        for base in ('/usr/bin', '/bin'):
            if os.path.isfile(f'/bedrock/strata/{stratum}{base}/{pm}'):
                return pm
    return None


def pkg_count(stratum: str, pm: Optional[str]) -> int:
    if not pm:
        return 0
    cmds = {
        'pacman':       'pacman -Qq 2>/dev/null | wc -l',
        'dnf':          'rpm -qa 2>/dev/null | wc -l',
        'apt-get':      'dpkg-query -W 2>/dev/null | wc -l',
        'zypper':       'rpm -qa 2>/dev/null | wc -l',
        'xbps-install': 'xbps-query -l 2>/dev/null | wc -l',
        'apk':          'apk list -I 2>/dev/null | wc -l',
        'emerge':       "(qlist -I 2>/dev/null || ls -d /var/db/pkg/*/* 2>/dev/null) | wc -l",
    }
    r = run(['strat', stratum, 'sh', '-c', cmds.get(pm, 'true')], timeout=15)
    try:
        return int(r.stdout.strip() or '0')
    except ValueError:
        return 0


def get_disk(path: str = '/') -> str:
    try:
        st = os.statvfs(path)
    except OSError:
        return 'unknown'
    total = st.f_blocks * st.f_frsize
    free  = st.f_bavail * st.f_frsize
    used  = total - free
    if total <= 0:
        return 'unknown'
    pct = used * 100 // total
    return f'{used / 1024**3:.1f} GiB / {total / 1024**3:.1f} GiB ({pct}%)'


def get_strata_info() -> list[tuple[str, Optional[str], int]]:
    strata = [s.strip() for s in run(['brl', 'list']).stdout.splitlines() if s.strip()]
    out = []
    for s in strata:
        pm = detect_pm(s)
        out.append((s, pm, pkg_count(s, pm)))
    return out


def get_active_bootloader() -> str:
    if not shutil.which('efibootmgr'):
        return 'unknown'
    r = run(['efibootmgr', '-v'])
    if r.returncode != 0:
        return 'unknown'
    boot_current = next((line.split(':', 1)[1].strip()
                         for line in r.stdout.splitlines()
                         if line.startswith('BootCurrent:')), None)
    if not boot_current:
        return 'unknown'
    for line in r.stdout.splitlines():
        if line.startswith(f'Boot{boot_current}'):
            low = line.lower()
            if 'systemd-boot' in low or '\\systemd\\' in low:
                return 'systemd-boot'
            if 'grub' in low:
                return 'GRUB'
            return 'unknown'
    return 'unknown'


def get_kernel() -> str:
    return run(['uname', '-r']).stdout.strip() or 'unknown'


def get_cpu() -> str:
    try:
        model = ''
        cores = 0
        with open('/proc/cpuinfo') as f:
            for line in f:
                if not model and line.startswith('model name'):
                    model = line.split(':', 1)[1].strip()
                if line.startswith('processor'):
                    cores += 1
        model = re.sub(r'\s*\b\d+-Core Processor\b', '', model)
        model = re.sub(r'\s*\bProcessor\b', '', model)
        model = re.sub(r'\s*\bCPU\b', '', model)
        model = re.sub(r'\s*@\s*[\d.]+\s*GHz', '', model)
        model = re.sub(r'\s+', ' ', model).strip()
        return f'{model} ({cores})' if model else 'unknown'
    except OSError:
        return 'unknown'


def _clean_gpu_name(s: str) -> str:
    for noise in (
        r'\bCorporation\b', r'\bAdvanced Micro Devices, Inc\.\s*',
        r'\bIntel\s+Corporation\b', r'\[AMD/ATI\]\s*',
        r'\(rev [0-9a-f]+\)', r'\bInc\.\b',
    ):
        s = re.sub(noise, '', s)
    m = re.search(r'^(\S+).*\[([^\]]+)\]', s)
    if m:
        s = f'{m.group(1)} {m.group(2)}'
    return re.sub(r'\s+', ' ', s).strip()


_AMD_IGPU_HINTS = (
    'Raphael', 'Phoenix', 'Rembrandt', 'Cezanne', 'Renoir', 'Picasso',
    'Lucienne', 'Granite Ridge', 'Strix', 'Hawk Point',
)


def get_gpu() -> str:
    """Pick a single primary GPU.

    Priority (lower number wins): NVIDIA > discrete AMD > integrated AMD/Intel
    > anything else. Matches what most fetch tools default to — on a hybrid
    laptop or NVIDIA-paired desktop you almost always want the discrete card.
    """
    if not shutil.which('lspci'):
        return 'unknown'
    r = run(['lspci', '-mm'])
    if r.returncode != 0:
        return 'unknown'
    candidates: list[tuple[int, str]] = []
    for line in r.stdout.splitlines():
        if not any(t in line for t in ('"VGA', '"3D', '"Display')):
            continue
        fields = re.findall(r'"([^"]*)"', line)
        if len(fields) < 3:
            continue
        vendor, device = fields[1], fields[2]
        name = _clean_gpu_name(f'{vendor} {device}')
        v_up = vendor.upper()
        if 'NVIDIA' in v_up:
            priority = 0
        elif 'AMD' in v_up or 'ATI' in v_up or 'ADVANCED MICRO' in v_up:
            integrated = any(hint in device for hint in _AMD_IGPU_HINTS)
            priority = 2 if integrated else 1
        elif 'INTEL' in v_up:
            priority = 2
        else:
            priority = 3
        candidates.append((priority, name))
    if not candidates:
        return 'unknown'
    candidates.sort(key=lambda x: x[0])
    return candidates[0][1]


def get_memory() -> str:
    try:
        with open('/proc/meminfo') as f:
            data = f.read()
        total = int(re.search(r'MemTotal:\s+(\d+)', data).group(1)) * 1024
        avail = int(re.search(r'MemAvailable:\s+(\d+)', data).group(1)) * 1024
        used = total - avail
        pct = used * 100 // total
        return f'{used / 1024**3:.1f} GiB / {total / 1024**3:.1f} GiB ({pct}%)'
    except (OSError, AttributeError, ValueError):
        return 'unknown'


def get_uptime() -> str:
    try:
        with open('/proc/uptime') as f:
            seconds = float(f.read().split()[0])
    except OSError:
        return 'unknown'
    d, rem = divmod(int(seconds), 86400)
    h, rem = divmod(rem, 3600)
    m, _ = divmod(rem, 60)
    parts = []
    if d: parts.append(f'{d}d')
    if h: parts.append(f'{h}h')
    if m or not parts: parts.append(f'{m}m')
    return ' '.join(parts)


def get_shell() -> str:
    sh_path = os.environ.get('SHELL', '/bin/sh')
    name = os.path.basename(sh_path)
    if name == 'zsh':
        r = run([sh_path, '--version'])
        if r.returncode == 0:
            return r.stdout.split('(', 1)[0].strip()
    elif name in ('bash',):
        r = run([sh_path, '--version'])
        if r.returncode == 0:
            line = r.stdout.splitlines()[0]
            m = re.search(r'version (\S+)', line)
            if m:
                return f'bash {m.group(1)}'
    elif name == 'fish':
        r = run([sh_path, '--version'])
        if r.returncode == 0:
            return r.stdout.strip()
    return name


