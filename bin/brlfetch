@dataclass
class Persona:
    name: str
    os_name: str
    hostname: str
    logo: str
    color: str
    stratum: Optional[str] = None
    fake_pm: Optional[str] = None
    fake_pkgs: Optional[int] = None
    fake_kernel_suffix: Optional[str] = None
    is_bedrock: bool = False


def fake_kernel_for(persona: 'Persona', real_kernel: str) -> str:
    """Rewrite the real kernel string so it looks distro-native.

    Keeps the major.minor.patch (e.g. "7.0.4") so the disguise stays plausible
    against `uname -r` parity — Bedrock processes really are running on that
    kernel — but swaps the distro suffix to match the persona.
    """
    if persona.is_bedrock or not persona.fake_kernel_suffix:
        return real_kernel
    m = re.match(r'(\d+\.\d+(?:\.\d+)?)', real_kernel)
    base = m.group(1) if m else real_kernel.split('-', 1)[0]
    sep = '' if persona.fake_kernel_suffix.startswith('_') else '-'
    return f'{base}{sep}{persona.fake_kernel_suffix}'


def _fake_pkg_count(salt: str, lo: int, hi: int) -> int:
    """Stable per-machine fake count in [lo, hi].

    Real stratum package counts on this Bedrock box are tiny (e.g. arch 889,
    debian 80) because they were freshly bootstrapped — totally unrealistic
    for someone's daily-driver distro. Disguises use plausible ranges instead:
    matches what `fastfetch` would show on a regular install of that distro.
    """
    host = os.uname().nodename
    seed = sum(ord(c) for c in host) * 17 + sum(ord(c) for c in salt) * 31
    span = hi - lo + 1
    return lo + (seed % span) if span > 0 else lo


