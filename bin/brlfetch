def _print_logo_info(logo_lines: list[str], info: 'Table', color: str):
    """Render logo + info side-by-side, falling back to stacked layout when
    the terminal isn't wide enough to fit both without wrapping info values.
    Re-queries console.width each call so successive invocations adapt to
    terminal resizes."""
    logo_w = max((len(line) for line in logo_lines), default=0)
    info_min = console.measure(info).minimum
    width = console.width
    side_by_side = width >= logo_w + info_min + 4

    if side_by_side:
        logo = Text('\n'.join(logo_lines), style=f'bold {color}')
        layout = Table.grid(padding=(0, 1))
        layout.add_column(no_wrap=True)
        layout.add_column()
        layout.add_row(logo, info)
        console.print(layout)
        return

    logo = Text('\n'.join(logo_lines), style=f'bold {color}')
    console.print(Align.center(logo))
    console.print(Align.center(info))


def render(persona: Persona):
    user = os.environ.get('USER', '?')
    real_host = run(['hostname']).stdout.strip() or '?'
    hostname = real_host if persona.is_bedrock else persona.hostname
    label_color = persona.color
    accent = persona.color

    bedrock_ver = get_bedrock_version()
    kernel      = fake_kernel_for(persona, get_kernel())
    uptime      = get_uptime()
    bootloader  = get_active_bootloader()
    cpu         = get_cpu()
    gpu         = get_gpu()
    mem         = get_memory()

    info = Table.grid(padding=(0, 2))
    info.add_column(style=f'bold {label_color}', justify='right', no_wrap=True)
    info.add_column(overflow='fold')

    header = (f'[bold {label_color}]{user}[/bold {label_color}]'
              f'[dim]@[/dim][bold {label_color}]{hostname}[/bold {label_color}]')
    sep_len = len(user) + 1 + len(hostname)
    info.add_row('', header)
    info.add_row('', '─' * sep_len)

    if persona.is_bedrock:
        info.add_row('OS', bedrock_ver)
        info.add_row('Hijacked from', get_hijacked_from())
        info.add_row('Host (init)', get_init_stratum())
    else:
        info.add_row('OS', persona.os_name)

    info.add_row('Kernel', kernel)
    info.add_row('Uptime', uptime)
    info.add_row('Bootloader', bootloader)
    info.add_row('CPU', cpu)
    info.add_row('GPU', gpu)
    info.add_row('Memory', mem)
    info.add_row('Disk (/)', get_disk('/'))
    info.add_row('', '')

    if persona.is_bedrock:
        strata = get_strata_info()
        info.add_row('Strata', f'[dim]({len(strata)})[/dim]')
        pm_width = max((len(pm) for _, pm, _ in strata if pm), default=4)
        for name, pm, cnt in strata:
            if pm is None:
                right = '[dim](meta)[/dim]'
            else:
                right = f'[dim]{pm:<{pm_width}}[/dim]  {cnt:>5} pkg'
            info.add_row(f'  [{accent}]·[/{accent}] {name}', right)
    else:
        info.add_row('Packages', f'{persona.fake_pkgs} ({persona.fake_pm})')

    logo_lines = persona.logo.strip('\n').splitlines()
    _print_logo_info(logo_lines, info, persona.color)


MINIMAL_LOGO = r"""
 __
 \ \___
  \  _ \
   \___/
""".rstrip('\n')


def render_minimal():
    """Compact view for shell startup: 5 fields + tiny logo."""
    user = os.environ.get('USER', '?')
    real_host = run(['hostname']).stdout.strip() or '?'

    info = Table.grid(padding=(0, 2))
    info.add_column(style='bold cyan', justify='right', no_wrap=True)
    info.add_column(overflow='fold')

    header = (f'[bold cyan]{user}[/bold cyan]'
              f'[dim]@[/dim][bold cyan]{real_host}[/bold cyan]')
    sep_len = len(user) + 1 + len(real_host)
    info.add_row('', header)
    info.add_row('', '─' * sep_len)
    info.add_row('Hijacked', get_hijacked_from())
    info.add_row('Kernel',   get_kernel())
    info.add_row('Uptime',   get_uptime())
    info.add_row('Memory',   get_memory())
    info.add_row('Shell',    get_shell())

    logo_lines = MINIMAL_LOGO.strip('\n').splitlines()
    _print_logo_info(logo_lines, info, 'cyan')


def disguise_command_line(replacement: str = 'fastfetch'):
    """Overwrite the previous terminal line (the user's `brlfetch <persona>`
    command) with `<prompt> fastfetch`, so anyone looking at the scrollback
    sees what looks like a plain fastfetch invocation. Best-effort: requires
    a TTY and an oh-my-zsh-style prompt to look natural.
    """
    if not sys.stdout.isatty():
        return
    prompt = '\x1b[1;32m➜\x1b[0m  \x1b[36m~\x1b[0m '
    sys.stdout.write('\x1b[A\r\x1b[2K' + prompt + replacement + '\n')
    sys.stdout.flush()


def emit_json():
    """Machine-readable dump of the same fields the full view shows."""
    import json
    strata = []
    for name, pm, cnt in get_strata_info():
        strata.append({
            'name': name,
            'pm': pm,
            'packages': cnt,
            'is_meta': pm is None,
        })
    try:
        st = os.statvfs('/')
        disk_total = st.f_blocks * st.f_frsize
        disk_free  = st.f_bavail * st.f_frsize
    except OSError:
        disk_total = disk_free = 0
    data = {
        'user': os.environ.get('USER', '?'),
        'hostname': run(['hostname']).stdout.strip() or '?',
        'bedrock_version': get_bedrock_version(),
        'hijacked_from': get_hijacked_from(),
        'init_stratum': get_init_stratum(),
        'kernel': get_kernel(),
        'uptime_seconds': int(float(open('/proc/uptime').read().split()[0]))
            if os.path.exists('/proc/uptime') else 0,
        'bootloader': get_active_bootloader(),
        'cpu': get_cpu(),
        'gpu': get_gpu(),
        'memory': get_memory(),
        'shell': get_shell(),
        'disk_root_bytes_total': disk_total,
        'disk_root_bytes_used': disk_total - disk_free,
        'strata': strata,
    }
    print(json.dumps(data, indent=2))


def main():
    ap = argparse.ArgumentParser(
        prog='brlfetch',
        description='Bedrock Linux fetch tool.',
    )
    ap.add_argument('persona', nargs='?', help=argparse.SUPPRESS)
    ap.add_argument('-m', '--minimal', action='store_true',
                    help='compact 5-field view for shell startup')
    ap.add_argument('-j', '--json', action='store_true',
                    help='emit machine-readable JSON instead of the TUI panel')
    ap.add_argument('--no-disguise', action='store_true',
                    help='do not rewrite the command line when invoking a persona')
    ap.add_argument('--run_test', action='store_true', help=argparse.SUPPRESS)
    args = ap.parse_args()

    if args.run_test:
        bail()
    verify_bedrock()

    if args.json:
        emit_json()
        return

    if args.minimal:
        render_minimal()
        return

    chosen = PERSONAS[0]
    matched = False
    if args.persona:
        want = args.persona.lower()
        for p in PERSONAS:
            if p.name.lower() == want:
                chosen = p
                matched = True
                break
    if matched and not chosen.is_bedrock and not args.no_disguise:
        disguise_command_line()
    render(chosen)


if __name__ == '__main__':
    main()
